# --- Obligatorias ---
GROQ_API_KEY=gsk_...
PINECONE_API_KEY=pcsk_...

# --- Opcional (solo para --use-semantic) ---
GEMINI_API_KEY=

# --- Pinecone (opcional, tienen defaults sensatos) ---
PINECONE_INDEX_NAME=cv-rag
PINECONE_NAMESPACE=recursive
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Modelos ---
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.2

# --- RAG params ---
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Paths ---
# CVS_DIR=/ruta/absoluta/a/data/cvs
